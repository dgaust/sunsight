# Copy to .env and fill in. .env is gitignored.
# Only needed to regenerate tests/fixtures/devices.json — the cards
# themselves never use this.
#
# Base URL of your Home Assistant instance, no trailing slash.
HA_URL=http://homeassistant.local:8123
# Long-lived access token: HA profile page -> Security -> Long-lived access tokens.
HA_TOKEN=
